{
  "name": "ai-voice",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=20.18.0", "pnpm": ">=9.0.0" },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:start": "pnpm --filter @ai-voice/db run start",
    "db:reset": "pnpm --filter @ai-voice/db run reset",
    "db:gen-types": "pnpm --filter @ai-voice/db run gen-types"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@types/node": "^20.14.0"
  }
}
